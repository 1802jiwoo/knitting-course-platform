erDiagram

USER {
    int user_id PK
    string email
    string password
    string nickname
    string role
    datetime created_at
}

LECTURE {
    int lecture_id PK
    string title
    text description
    string lecture_type
    string instructor_name
    datetime created_at
}

LECTURE_PART {
    int part_id PK
    int lecture_id FK
    string title
    int order_no
}

VIDEO {
    int video_id PK
    int part_id FK
    string youtube_url
    int duration
}

LECTURE_PATTERN {
    int pattern_id PK
    int lecture_id FK
    int row_num
    text pattern_text
}

PART_PATTERN {
    int pattern_id PK
    int part_id FK
    int start_time
    int end_time
    int row_num
    text pattern_text
}

PATTERN_SYMBOL {
    int symbol_id PK
    string symbol
    string description
}

TAG {
    int tag_id PK
    string tag_name
}

LECTURE_TAG {
    int lecture_id FK
    int tag_id FK
}

QUESTION {
    int question_id PK
    int user_id FK
    int lecture_id FK
    string title
    text content
    string image_url
    datetime created_at
}

ANSWER {
    int answer_id PK
    int question_id FK
    int instructor_id FK
    text content
    datetime created_at
}

ENROLLMENT {
    int enrollment_id PK
    int user_id FK
    int lecture_id FK
    int completed_parts
    int total_parts
    int progress
    datetime created_at
}

USER ||--o{ LECTURE : creates
LECTURE ||--o{ LECTURE_PART : contains
LECTURE_PART ||--o| VIDEO : has
LECTURE ||--o{ LECTURE_PATTERN : has
LECTURE_PART ||--o{ PART_PATTERN : includes

LECTURE ||--o{ LECTURE_TAG : tagged
TAG ||--o{ LECTURE_TAG : used_in

USER ||--o{ QUESTION : asks
LECTURE ||--o{ QUESTION : has
QUESTION ||--o{ ANSWER : receives

USER ||--o{ ENROLLMENT : enrolls
LECTURE ||--o{ ENROLLMENT : enrolled_in
